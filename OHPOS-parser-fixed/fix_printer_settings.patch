+        Text(
+            text = title,
+            style = AppTheme.typography.bodyLarge,
+            color = AppTheme.colors.textPrimary,
+            modifier = Modifier.weight(1f)
+        )
+        Switch(checked = checked, onCheckedChange = onCheckedChange)

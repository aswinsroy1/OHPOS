<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_receipt_outline">
    
    <target android:name="outline">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="350"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="line1">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="350"
                android:duration="150"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="line2">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="420"
                android:duration="150"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="line3">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <objectAnimator
